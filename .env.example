# App
NODE_ENV=development
PORT=3000
PERSISTENCE_MODE=auto

# Auth
ADMIN_JWT_SECRET=changeme-super-secret
ROOT_EMAIL=root@unam.edu.ar
ROOT_LOGIN=root-unam
ROOT_PASSWORD=changeme-root-password
GOOGLE_CLIENT_ID=
ALLOWED_PUBLIC_EMAILS=
REQUIRE_HTTPS=false
TRUST_PROXY_HEADERS=true

# PostgreSQL (usar DATABASE_URL o DB_*)
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/ead
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=ead
DB_USER=postgres
DB_PASSWORD=postgres

# SSL
# PGSSL_DISABLE=true

# SMTP compartido: notificaciones a interesados + digest semanal del newsletter
# (se puede sobrescribir para newsletter con NEWSLETTER_SMTP_HOST/PORT/USER/PASS y NEWSLETTER_FROM)
NOTIFY_SMTP_HOST=smtp-mail.outlook.com
NOTIFY_SMTP_PORT=587
NOTIFY_SMTP_USER=joel_barrera@outlook.com
NOTIFY_SMTP_PASS=tu-contraseña-o-app-password
NOTIFY_FROM=EAD Novedades <joel_barrera@outlook.com>
# PUBLIC_URL=https://tu-sitio.com

# Límites de carga admin (opcional)
# ADMIN_MAX_UPLOAD_MB=20
# ADMIN_MAX_REQUEST_MB=50
# ADMIN_MAX_CHUNK_MB=6
# MAX_REQUEST_MB=50

# JSON fallback (solo si PERSISTENCE_MODE=json o auto sin DB)
# JSON_DB_PATH=backend/data/db.json
